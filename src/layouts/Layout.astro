---
import { ScrollToTop } from "@/components/ui/ScrollToTop";
import { CookieBanner } from "@/components/ui/CookieBanner";

interface Props {
  title?: string;
  description?: string;
}

const siteUrl = 'https://cerveceriaburgos.es';
const ogImage = `${siteUrl}/images/gallery/coctel-1.webp`;

const { 
  title = "Cervecería Burgos | Cerveza y Tapas en Carabanchel, Madrid",
  description = "Cervecería Burgos - Cervezas bien frías, tapas generosas y buen ambiente en Carabanchel, Madrid. Desde 2015. Calle Eugenia de Montijo, 80."
} = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Restaurant",
      "name": "Cervecería Burgos",
      "description": "Cervecería con cervezas bien frías, tapas generosas y terraza en Carabanchel, Madrid.",
      "url": siteUrl,
      "image": ogImage,
      "telephone": "+34625047070",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Calle Eugenia de Montijo, 80",
        "addressLocality": "Madrid",
        "postalCode": "28025",
        "addressRegion": "Madrid",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 40.3786239,
        "longitude": -3.7477972
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "07:30",
          "closes": "00:30"
        }
      ],
      "priceRange": "€",
      "servesCuisine": "Tapas, Cerveza",
      "acceptsReservations": "True"
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Inicio",
          "item": siteUrl
        }
      ]
    }
  ]
};
---

<!DOCTYPE html>
<html lang="es">
  <script is:inline>
    (function() {
      var lang = localStorage.getItem('lang') || (navigator.language.split('-')[0] === 'en' ? 'en' : 'es');
      document.documentElement.lang = lang;
      var skip = document.getElementById('skip-link');
      if (skip) skip.textContent = lang === 'en' ? 'Skip to main content' : 'Saltar al contenido principal';
    })();
  </script>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#99120f" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_ES" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}favicon.svg`} />
    <link rel="manifest" href={`${import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : import.meta.env.BASE_URL + '/'}manifest.json`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" as="style" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet" />
    
    <title>{title}</title>
    <script is:inline>
      (function() {
        var lang = localStorage.getItem('lang') || (navigator.language.split('-')[0] === 'en' ? 'en' : 'es');
        if (lang === 'en') {
          var t = document.title;
          var map = {
            'Aviso Legal | Cervecería Burgos': 'Legal Notice | Cervecería Burgos',
            'Política de Cookies | Cervecería Burgos': 'Cookie Policy | Cervecería Burgos',
            'Política de Privacidad | Cervecería Burgos': 'Privacy Policy | Cervecería Burgos',
            '404 | Cervecería Burgos': '404 | Cervecería Burgos',
            'Cervecería Burgos | Cerveza y Tapas en Carabanchel, Madrid': 'Cervecería Burgos | Beer and Tapas in Carabanchel, Madrid'
          };
          if (map[t]) document.title = map[t];
          var desc = document.querySelector('meta[name="description"]');
          if (desc) desc.setAttribute('content', 'Cervecería Burgos - Ice-cold beers, generous tapas and great atmosphere in Carabanchel, Madrid. Since 2015. Calle Eugenia de Montijo, 80.');
          var ogTitle = document.querySelector('meta[property="og:title"]');
          if (ogTitle && map[t]) ogTitle.setAttribute('content', map[t]);
          var ogDesc = document.querySelector('meta[property="og:description"]');
          if (ogDesc) ogDesc.setAttribute('content', 'Cervecería Burgos - Ice-cold beers, generous tapas and great atmosphere in Carabanchel, Madrid. Since 2015.');
          var ogLocale = document.querySelector('meta[property="og:locale"]');
          if (ogLocale) ogLocale.setAttribute('content', 'en_GB');
          var twitterTitle = document.querySelector('meta[name="twitter:title"]');
          if (twitterTitle && map[t]) twitterTitle.setAttribute('content', map[t]);
          var twitterDesc = document.querySelector('meta[name="twitter:description"]');
          if (twitterDesc) twitterDesc.setAttribute('content', 'Cervecería Burgos - Ice-cold beers, generous tapas and great atmosphere in Carabanchel, Madrid. Since 2015.');
        }
      })();
    </script>
    <script is:inline>
      window.__GA_ID__ = 'G-44E9DNWD8P';
    </script>
  </head>
  <body class="antialiased">
    <a id="skip-link" href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-[60] focus:px-4 focus:py-2 focus:bg-[#99120f] focus:text-[#FBF5DD] focus:rounded-lg focus:font-medium">
      Saltar al contenido principal
    </a>
    <main id="main-content">
      <slot />
    </main>
    <ScrollToTop client:load />
    <CookieBanner client:load />
  </body>
</html>

<style>
  @import "../styles/global.css";
</style>
