---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Página no encontrada | Cervecería Burgos">
  <section class="min-h-screen flex items-center justify-center px-4" style="background-color: #FBF5DD;">
    <div class="text-center">
      <h1 class="text-6xl font-bold text-[#99120f] mb-4">404</h1>
      <p class="text-xl text-[#151418] mb-8">Página no encontrada</p>
      <p class="text-[#A06029] mb-8">Lo sentimos, no hemos podido encontrar la página que buscas.</p>
      <a
        href="/"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#99120f] text-[#FBF5DD] font-medium rounded-xl hover:bg-[#99120f]/90 transition-colors"
      >
        Volver al inicio
      </a>
    </div>
  </section>
</Layout>
